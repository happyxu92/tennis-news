<section style="font-size:16px;line-height:1.75;color:#1f2937;">
  <p style="margin:0 0 8px;font-size:12px;font-weight:700;letter-spacing:0.08em;color:#2563eb;">{{ article_label }}</p>
  <h1 style="margin:0 0 12px;font-size:28px;line-height:1.35;color:#111827;">{{ title }}</h1>
  <p style="margin:0 0 10px;font-size:15px;line-height:1.7;color:#475569;">{{ summary }}</p>
  <p style="margin:0 0 22px;font-size:13px;color:#64748b;">更新时间（{{ timezone_label }}）：{{ updated_at_text }}</p>
  {% if courts %}
  {% for court in courts %}
  <section style="margin:0 0 18px;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
    <div style="padding:12px 14px;background-color:#f3f7ff;border-bottom:1px solid #e5e7eb;">
      <p style="margin:0;font-size:18px;font-weight:700;line-height:1.4;color:#111827;">{{ court.name }}</p>
      <p style="margin:4px 0 0;font-size:13px;line-height:1.6;color:#475569;">共 {{ court.match_count }} 场{% if court.key_match_count %}，焦点战 {{ court.key_match_count }} 场{% endif %}</p>
    </div>
    {% for match in court.matches %}
    <section style="padding:14px 14px 12px;{% if not loop.first %}border-top:1px solid #f1f5f9;{% endif %}">
      <p style="margin:0 0 6px;font-size:13px;line-height:1.6;color:#64748b;">{{ match.round_name or "轮次待定" }} ｜ {{ match.status_label }}</p>
      <p style="margin:0 0 8px;font-size:18px;line-height:1.55;font-weight:700;color:#111827;">{{ match.player1_name or "待定选手" }} vs {{ match.player2_name or "待定选手" }}{% if match.is_key_match %}<span style="display:inline-block;margin-left:8px;padding:1px 8px;border-radius:999px;background-color:#fee2e2;color:#b91c1c;font-size:12px;font-weight:700;line-height:1.7;vertical-align:middle;">焦点</span>{% endif %}</p>
      <p style="margin:0;font-size:14px;line-height:1.75;color:#475569;">时间（{{ timezone_label }}）：{{ match.time_text }}{% if match.court_name %} ｜ 场地：{{ match.court_name }}{% endif %}</p>
    </section>
    {% endfor %}
  </section>
  {% endfor %}
  {% else %}
  <section style="padding:18px 16px;border:1px dashed #cbd5e1;border-radius:12px;background-color:#f8fafc;">
    <p style="margin:0;font-size:14px;line-height:1.75;color:#475569;text-align:center;">当前日期暂无已同步赛程，请稍后刷新。</p>
  </section>
  {% endif %}
</section>
